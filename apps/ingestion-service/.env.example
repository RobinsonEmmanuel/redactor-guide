# Port du microservice (défaut: 4001)
PORT=4001

# MongoDB (partagé avec apps/api)
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=redactor_guide

# Clé secrète pour authentifier les appels entrants (header X-Api-Key)
# Doit correspondre à INGESTION_SERVICE_API_KEY dans apps/api/.env
API_KEY_SECRET=change_me_secret

# QStash — pour les jobs asynchrones (optionnel en dev)
QSTASH_TOKEN=
# URL publique de CE service (pour que QStash rappelle les workers)
INGEST_WORKER_URL=http://localhost:4001

# OpenAI — pour la détection POI et la déduplication
OPENAI_API_KEY=sk-...

# Region Lovers API
REGION_LOVERS_API_URL=https://api-prod.regionlovers.ai

# IDs des prompts en MongoDB (optionnel — utilise les défauts si absent)
PROMPT_ID_POI_EXTRACTION=prompt_1770544848350_9j5m305ukj
PROMPT_ID_POI_DEDUP=deduplication_POI_24022026
