# Port du microservice (défaut: 4001)
PORT=4001

# MongoDB (partagé avec apps/api)
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=redactor_guide

# Clé secrète pour authentifier les appels entrants (header X-Api-Key)
# Doit correspondre à INGESTION_SERVICE_API_KEY dans apps/api/.env
API_KEY_SECRET=change_me_secret

# QStash — pour les jobs d'ingestion asynchrones (optionnel en dev)
QSTASH_TOKEN=
# URL publique de CE service (pour que QStash rappelle /api/v1/ingest/run)
INGEST_WORKER_URL=http://localhost:4001
